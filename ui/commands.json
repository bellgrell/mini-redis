  { "cmd": "LINDEX", "args": "<key> <index>", "desc": "Get an element from a list by index", "group": "lists", "syntax": "LINDEX <key> <index>", "example": "LINDEX mylist 0", "returns": "value or (nil)" },
  { "cmd": "SADD", "args": "<key> <mem> [mem...]", "desc": "Add one or more members to a set", "group": "sets", "syntax": "SADD <key> <member> [member ...]", "example": "SADD myset member1 member2", "returns": "(integer) added count" },
  { "cmd": "SREM", "args": "<key> <mem> [mem...]", "desc": "Remove one or more members from a set", "group": "sets", "syntax": "SREM <key> <member> [member ...]", "example": "SREM myset member1", "returns": "(integer) removed count" },
  { "cmd": "SMEMBERS", "args": "<key>", "desc": "Get all members in a set", "group": "sets", "syntax": "SMEMBERS <key>", "example": "SMEMBERS myset", "returns": "Array of members" },
  { "cmd": "SISMEMBER", "args": "<key> <member>", "desc": "Check if a value is a member of a set", "group": "sets", "syntax": "SISMEMBER <key> <member>", "example": "SISMEMBER myset member1", "returns": "(integer) 0 or 1" },
  { "cmd": "SCARD", "args": "<key>", "desc": "Get the number of members in a set", "group": "sets", "syntax": "SCARD <key>", "example": "SCARD myset", "returns": "(integer) count" },
