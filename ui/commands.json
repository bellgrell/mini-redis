  { "cmd": "HEXISTS", "args": "<key> <field>", "desc": "Check if a hash field exists", "group": "hashes", "syntax": "HEXISTS <key> <field>", "example": "HEXISTS user:1001 name", "returns": "(integer) 0 or 1" },
  { "cmd": "HLEN", "args": "<key>", "desc": "Get the number of fields in a hash", "group": "hashes", "syntax": "HLEN <key>", "example": "HLEN user:1001", "returns": "(integer) count" },
  { "cmd": "HKEYS", "args": "<key>", "desc": "Get all field names in a hash", "group": "hashes", "syntax": "HKEYS <key>", "example": "HKEYS user:1001", "returns": "Array of field names" },
  { "cmd": "HVALS", "args": "<key>", "desc": "Get all values in a hash", "group": "hashes", "syntax": "HVALS <key>", "example": "HVALS user:1001", "returns": "Array of values" },
  { "cmd": "ZADD", "args": "<key> <score> <member>", "desc": "Add a member with a score to a sorted set", "group": "sorted-sets", "syntax": "ZADD <key> <score> <member> [<score> <member> ...]", "example": "ZADD leaderboard 100 player1", "returns": "(integer) added count" },
  { "cmd": "ZREM", "args": "<key> <member>", "desc": "Remove a member from a sorted set", "group": "sorted-sets", "syntax": "ZREM <key> <member> [member ...]", "example": "ZREM leaderboard player1", "returns": "(integer) removed count" },
  { "cmd": "ZRANGE", "args": "<key> <start> <stop>", "desc": "Get a range of members from a sorted set", "group": "sorted-sets", "syntax": "ZRANGE <key> <start> <stop> [WITHSCORES]", "example": "ZRANGE leaderboard 0 -1 WITHSCORES", "returns": "Array of members or (member, score)" },
  { "cmd": "ZCARD", "args": "<key>", "desc": "Get the number of members in a sorted set", "group": "sorted-sets", "syntax": "ZCARD <key>", "example": "ZCARD leaderboard", "returns": "(integer) count" },
