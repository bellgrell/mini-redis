[
  { "cmd": "PING", "args": "", "desc": "Test connection", "group": "connection", "syntax": "PING", "example": "PING", "returns": "PONG" },
  { "cmd": "ECHO", "args": "<message>", "desc": "Echo a message", "group": "connection", "syntax": "ECHO <message>", "example": "ECHO hello", "returns": "hello" },
  { "cmd": "QUIT", "args": "", "desc": "Close connection", "group": "connection", "syntax": "QUIT", "example": "QUIT", "returns": "OK" },
  { "cmd": "SET", "args": "<key> <value>", "desc": "Set a key-value pair (with optional EX/PX/NX/XX)", "group": "strings", "syntax": "SET <key> <value> [EX <s>] [PX <ms>] [NX|XX]", "example": "SET mykey \"Hello\"", "returns": "OK" },
  { "cmd": "GET", "args": "<key>", "desc": "Get value by key", "group": "strings", "syntax": "GET <key>", "example": "GET mykey", "returns": "value or (nil)" },
  { "cmd": "DEL", "args": "<key> [key...]", "desc": "Delete one or more keys", "group": "generic", "syntax": "DEL <key> [key ...]", "example": "DEL mykey", "returns": "(integer) count" },
  { "cmd": "EXISTS", "args": "<key> [key...]", "desc": "Check if one or more keys exist", "group": "generic", "syntax": "EXISTS <key> [key ...]", "example": "EXISTS mykey", "returns": "(integer) 0 or 1" },
  { "cmd": "EXPIRE", "args": "<key> <seconds>", "desc": "Set a key's time to live in seconds", "group": "generic", "syntax": "EXPIRE <key> <seconds>", "example": "EXPIRE mykey 3600", "returns": "(integer) 1" },
  { "cmd": "TTL", "args": "<key>", "desc": "Get the remaining TTL of a key", "group": "generic", "syntax": "TTL <key>", "example": "TTL mykey", "returns": "(integer) seconds or -1" },
  { "cmd": "KEYS", "args": "<pattern>", "desc": "Find all keys matching the given pattern", "group": "generic", "syntax": "KEYS <pattern>", "example": "KEYS user:*", "returns": "Array of key names" },
  { "cmd": "TYPE", "args": "<key>", "desc": "Get the type of a key", "group": "generic", "syntax": "TYPE <key>", "example": "TYPE mykey", "returns": "string | list | set | hash | zset | none" },
  { "cmd": "RENAME", "args": "<key> <newkey>", "desc": "Rename a key", "group": "generic", "syntax": "RENAME <key> <newkey>", "example": "RENAME mykey mynewkey", "returns": "OK" },
  { "cmd": "APPEND", "args": "<key> <value>", "desc": "Append a value to a key's string", "group": "strings", "syntax": "APPEND <key> <value>", "example": "APPEND mykey \" World\"", "returns": "(integer) new length" },
  { "cmd": "STRLEN", "args": "<key>", "desc": "Get the length of a string value", "group": "strings", "syntax": "STRLEN <key>", "example": "STRLEN mykey", "returns": "(integer) length" },
  { "cmd": "INCR", "args": "<key>", "desc": "Increment integer value by 1", "group": "strings", "syntax": "INCR <key>", "example": "INCR counter", "returns": "(integer) new value" },
  { "cmd": "INCRBY", "args": "<key> <amount>", "desc": "Increment integer by a specified amount", "group": "strings", "syntax": "INCRBY <key> <amount>", "example": "INCRBY counter 5", "returns": "(integer) new value" },
  { "cmd": "DECR", "args": "<key>", "desc": "Decrement integer value by 1", "group": "strings", "syntax": "DECR <key>", "example": "DECR counter", "returns": "(integer) new value" },
  { "cmd": "DECRBY", "args": "<key> <amount>", "desc": "Decrement integer by a specified amount", "group": "strings", "syntax": "DECRBY <key> <amount>", "example": "DECRBY counter 5", "returns": "(integer) new value" },
  { "cmd": "GETSET", "args": "<key> <value>", "desc": "Set a key's value and return the old value", "group": "strings", "syntax": "GETSET <key> <value>", "example": "GETSET mykey \"new\"", "returns": "old value or (nil)" },
  { "cmd": "LPUSH", "args": "<key> <val> [val...]", "desc": "Prepend one or more values to a list", "group": "lists", "syntax": "LPUSH <key> <value> [value ...]", "example": "LPUSH mylist item1 item2", "returns": "(integer) new length" },
  { "cmd": "RPUSH", "args": "<key> <val> [val...]", "desc": "Append one or more values to a list", "group": "lists", "syntax": "RPUSH <key> <value> [value ...]", "example": "RPUSH mylist item1", "returns": "(integer) new length" },
  { "cmd": "LPOP", "args": "<key>", "desc": "Remove and get the first element in a list", "group": "lists", "syntax": "LPOP <key>", "example": "LPOP mylist", "returns": "value or (nil)" },
